  "info": {
    "description": "The trusted translation layer between computational-chemistry file formats, exposed as a REST API. Reports embed verbatim; refusals are HTTP 200 completed jobs.",
    "summary": "Loss-aware chemistry file conversion over HTTP.",
    "title": "Xtalate Service",
    "version": "0.4.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/v1/capabilities": {
      "get": {
        "description": "Every format's read/write capability declaration (equals ``xtalate capabilities --json``).",
        "operationId": "capabilities_v1_capabilities_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "additionalProperties": true,
                    "type": "object"
                  },
                  "title": "Response Capabilities V1 Capabilities Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Capabilities",
        "tags": [
          "capabilities"
        ]
      }
    },
    "/v1/capabilities/{format_id}": {
      "get": {
        "description": "One format's declaration as ``{format_id: {...}}`` (matches ``capabilities <id> --json``).",
        "operationId": "capabilities_for_format_v1_capabilities__format_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "format_id",
            "required": true,
            "schema": {
              "title": "Format Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "additionalProperties": true,
                    "type": "object"
                  },
                  "title": "Response Capabilities For Format V1 Capabilities  Format Id  Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Capabilities For Format",
        "tags": [
          "capabilities"
        ]
      }
    },
    "/v1/conversions/{conversion_id}": {
      "get": {
        "description": "The durable record for one conversion \u2014 both reports verbatim, byte availability computed.",
        "operationId": "get_conversion_record_v1_conversions__conversion_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "conversion_id",
            "required": true,
            "schema": {
              "title": "Conversion Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversionRecordResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Conversion Record",
        "tags": [
          "conversions"
        ]
      }
    },
    "/v1/convert": {
      "post": {
        "description": "Submit a conversion (Part 6 \u00a72.1). A refusal is a completed job, not an error (\u00a71).",
        "operationId": "convert_v1_convert_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConvertRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobEnvelope"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Convert"
      }
    },
    "/v1/download/{conversion_id}": {
      "get": {
        "description": "Stream a conversion's output bytes, guarded by the not-found / ack / expiry gates above.",
