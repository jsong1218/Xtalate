      "DownloadInfo": {
        "description": "The ``download`` object on a conversion record (Part 6 \u00a74.4).\n\n``available`` goes false once the output bytes pass their lifecycle window \u2014 the record and its\nreports remain retrievable, so a stale link renders as \"expired\", not \"not found\" (reports-\noutlive-bytes). ``requires_ack`` mirrors the download endpoint's failed-validation gate, so a UI\ncan pre-warn before the ``409``. ``size_bytes``/``expires_at`` are ``None`` once unavailable.",
        "properties": {
          "available": {
            "title": "Available",
            "type": "boolean"
          },
          "expires_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Expires At"
          },
          "filename": {
            "title": "Filename",
            "type": "string"
          },
          "requires_ack": {
            "title": "Requires Ack",
            "type": "boolean"
          },
          "size_bytes": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Size Bytes"
          }
        },
        "required": [
          "available",
          "requires_ack",
          "filename"
        ],
        "title": "DownloadInfo",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
