      },
      "HealthResponse": {
        "description": "``GET /v1/health`` \u2014 liveness always; readiness when ``?ready=true``.\n\nLiveness (``status == \"ok\"``, ``checks`` empty) proves the process is up. Readiness runs the\nregistered dependency checks (database and object storage, registered in M21); ``status`` is\n``\"ok\"`` only when every check passed, ``\"degraded\"`` otherwise, and the endpoint returns\n``503`` on ``degraded`` so an orchestrator's probe fails correctly.",
        "properties": {
          "checks": {
            "additionalProperties": {
              "$ref": "#/components/schemas/ReadinessCheck"
            },
            "title": "Checks",
            "type": "object"
          },
          "environment": {
            "title": "Environment",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "status",
          "environment",
          "version"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "HistoryItem": {
        "description": "One ``items[]`` entry from ``GET /v1/history`` (Part 6 \u00a74.4).\n\nA compact projection for the list view: source/target formats + filenames (the report's source\nminus hashes), the two statuses, and the ``summary_counts`` chips\n(``{preserved, removed, assumptions, warnings}``, counted from the conversion report \u2014 the\ncounts the v0.6 UI renders per ``07 \u00a74``). ``file_id`` is present only while the source upload\nis still live, which is what lets a UI offer a re-convert without a fresh upload (``07 \u00a72.6``).",
        "properties": {
          "conversion_id": {
            "title": "Conversion Id",
            "type": "string"
          },
          "conversion_status": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Conversion Status"
          },
          "created_at": {
            "title": "Created At",
            "type": "string"
          },
          "file_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "File Id"
          },
          "source": {
            "additionalProperties": true,
            "title": "Source",
            "type": "object"
          },
          "summary_counts": {
            "additionalProperties": {
              "type": "integer"
            },
            "title": "Summary Counts",
            "type": "object"
          },
          "target": {
            "additionalProperties": true,
            "title": "Target",
            "type": "object"
          },
          "validation_status": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Validation Status"
          }
        },
        "required": [
          "conversion_id",
          "created_at",
          "source",
          "target",
          "conversion_status",
          "summary_counts"
        ],
        "title": "HistoryItem",
        "type": "object"
      },
      "HistoryResponse": {
        "description": "``GET /v1/history`` \u2014 a page of :class:`HistoryItem` plus the opaque next-page cursor.\n\n``next_cursor`` is ``None`` on the last page; otherwise it is passed back as ``?cursor=`` to\nfetch the following page. Pagination is keyset over ``(created_at, conversion_id)`` descending\n(newest first), so a record added between page fetches never shifts or duplicates an item the\nway an offset would \u2014 the cursor names a fixed point in the ordering, not a position count.",
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/HistoryItem"
            },
            "title": "Items",
            "type": "array"
          },
          "next_cursor": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Next Cursor"
          }
        },
        "required": [
          "items"
        ],
        "title": "HistoryResponse",
        "type": "object"
      },
      "InspectRequest": {
        "description": "``POST /v1/inspect`` body \u2014 run the Information Discovery Engine on an uploaded file.",
        "properties": {
          "file_id": {
            "title": "File Id",
            "type": "string"
          },
          "format_override": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Format Override"
          }
        },
        "required": [
          "file_id"
        ],
        "title": "InspectRequest",
        "type": "object"
      },
      "JobEnvelope": {
        "description": "The full job envelope returned on submit and on every poll (Part 6 \u00a73.2).\n\n``result`` is the kind-specific completion payload (``None`` until the job completes):\n``{discovery_report}`` for inspect, ``{conversion_id, conversion_report, validation_report,\ndownload}`` for convert, ``{validation_report}`` for validate \u2014 each embedding the library's\nreport models verbatim. ``error`` is the error envelope's inner body (the same shape a non-2xx\nresponse carries) for a ``failed`` job, ``None`` otherwise. ``awaiting_recovery`` detail is an\nM23 addition to this same model \u2014 absent here, never a reshaping of what M22 established.",
        "properties": {
          "awaiting_recovery": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Awaiting Recovery"
          },
          "created_at": {
            "title": "Created At",
            "type": "string"
          },
          "error": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          },
          "expires_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Expires At"
          },
          "finished_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Finished At"
          },
          "job_id": {
            "title": "Job Id",
            "type": "string"
          },
          "kind": {
            "title": "Kind",
            "type": "string"
          },
          "progress": {
            "$ref": "#/components/schemas/JobProgress"
          },
          "result": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Result"
          },
          "started_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Started At"
          },
          "state": {
            "title": "State",
            "type": "string"
          },
          "updated_at": {
            "title": "Updated At",
            "type": "string"
          }
        },
        "required": [
          "job_id",
          "kind",
          "state",
          "created_at",
          "updated_at"
        ],
        "title": "JobEnvelope",
        "type": "object"
      },
      "JobProgress": {
        "description": "Coarse progress for a running job (Part 6 \u00a73.2).\n\n``phase`` names the pipeline stage the worker last entered (``\"parsing\"``, ``\"converting\"``,\n``\"validating\"``, \u2026); ``frames_processed``/``frames_total`` are the v0.3 chunked engine's frame\ncounters when a streamed operation exposes them, ``None`` otherwise. M22 stamps the phase at\neach stage boundary; live frame counters attach at the same seam with no shape change (**P6**).",
        "properties": {
          "frames_processed": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Frames Processed"
          },
          "frames_total": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Frames Total"
          },
          "phase": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Phase"
          }
        },
        "title": "JobProgress",
        "type": "object"
      },
      "LimitsResponse": {
        "description": "``GET /v1/limits`` \u2014 every Part 6 \u00a75 constraint, config-driven (Revisions 1.4, 1.5).\n\nA client reads the rules before hitting them. In M21 these are surfaced from configuration;\nthe surfaces that *enforce* them (upload streaming, rate limiting, the recovery pause) wire\nto the same values in M23/M24, so the advertised number and the enforced number are one thing.",
        "properties": {
          "awaiting_recovery_ttl_minutes": {
            "title": "Awaiting Recovery Ttl Minutes",
            "type": "integer"
          },
          "max_concurrent_jobs": {
            "title": "Max Concurrent Jobs",
            "type": "integer"
          },
          "max_frames": {
            "title": "Max Frames",
            "type": "integer"
          },
          "max_upload_bytes": {
            "title": "Max Upload Bytes",
            "type": "integer"
          },
          "output_retention_hours": {
            "title": "Output Retention Hours",
            "type": "integer"
          },
          "rate_limit_per_minute": {
            "title": "Rate Limit Per Minute",
            "type": "integer"
          },
          "report_retention_days": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Report Retention Days"
          },
          "upload_retention_hours": {
            "title": "Upload Retention Hours",
            "type": "integer"
          }
        },
        "required": [
          "max_upload_bytes",
          "max_frames",
          "max_concurrent_jobs",
          "rate_limit_per_minute",
          "upload_retention_hours",
          "output_retention_hours",
          "awaiting_recovery_ttl_minutes",
          "report_retention_days"
        ],
        "title": "LimitsResponse",
        "type": "object"
      },
      "ReadinessCheck": {
        "description": "One dependency's readiness result, reported by ``GET /v1/health?ready=true``.",
        "properties": {
          "detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Detail"
          },
          "ok": {
            "title": "Ok",
