# Xtalate Service — environment template (MASTER_SPEC Part 9 §2).
#
# Configuration is read from the process environment ONLY. Copy this file to `.env` for local
# development (it is gitignored); in Tier 1 / a hosted instance the same variables are set on the
# container. Every setting has a code default (see backend/config.py) — uncomment only what you
# need to override. Secrets are never committed: this template carries names and safe examples,
# never real credentials (CLAUDE.md "Never commit secrets").
#
# All keys use the XTALATE_ prefix.

# --- identity ---------------------------------------------------------------------------------
# Free-form deployment label; appears in logs and GET /v1/health. Never changes behaviour.
#XTALATE_ENVIRONMENT=development

# Base URL the error-envelope documentation_url links into (per-error anchor = the error `code`).
#XTALATE_DOCS_BASE_URL=https://github.com/jsong1218/Xtalate/blob/main/docs/API.md

# --- local dev server (python -m backend) -----------------------------------------------------
#XTALATE_HOST=127.0.0.1
#XTALATE_PORT=8000
#XTALATE_RELOAD=false

# --- limits (surfaced by GET /v1/limits; enforced in M23/M24) ---------------------------------
#XTALATE_MAX_UPLOAD_BYTES=104857600         # 100 MiB
#XTALATE_MAX_FRAMES=100000
#XTALATE_MAX_CONCURRENT_JOBS=4
#XTALATE_RATE_LIMIT_PER_MINUTE=120
#XTALATE_UPLOAD_RETENTION_HOURS=24
#XTALATE_OUTPUT_RETENTION_HOURS=24
#XTALATE_AWAITING_RECOVERY_TTL_MINUTES=30
#XTALATE_REPORT_RETENTION_DAYS=30           # empty = indefinite (self-hosted default)

# --- persistence & queue (wired in M21 slices 2–4; placeholders for the Tier 1 stack) ---------
# Database (SQLite for Tier 0, PostgreSQL for Tier 1). Example Tier 1 value:
#XTALATE_DATABASE_URL=postgresql+psycopg://xtalate:xtalate@postgres:5432/xtalate
# Object storage (local filesystem for Tier 0, S3/MinIO for Tier 1). Example Tier 1 values:
#XTALATE_OBJECT_STORE_ENDPOINT=http://minio:9000
#XTALATE_OBJECT_STORE_BUCKET=xtalate
#XTALATE_OBJECT_STORE_ACCESS_KEY=xtalate
#XTALATE_OBJECT_STORE_SECRET_KEY=change-me-in-your-own-.env
# Job queue (M22). Tier 0 default is `inline`: a submitted job runs synchronously in the API
# process, so no Redis and no separate worker are needed. Tier 1 sets `rq` and points at Redis; the
# API enqueues and the `backend.worker` process executes.
#XTALATE_QUEUE_BACKEND=rq
#XTALATE_REDIS_URL=redis://queue:6379/0
#XTALATE_QUEUE_NAME=xtalate
#XTALATE_JOB_TIMEOUT_SECONDS=1800

# --- Tier 1 compose (compose.yaml) ------------------------------------------------------------
# These are NOT read by the app (no XTALATE_ prefix) — `docker compose` interpolates them into the
# postgres/minio/queue services. `${VAR:-default}` means the environment wins; the defaults are
# LOCAL-DEV THROWAWAYS, never production secrets (CLAUDE.md "Never commit secrets"). Override every
# credential for anything reachable from outside your machine.
#POSTGRES_USER=xtalate
#POSTGRES_PASSWORD=xtalate
#POSTGRES_DB=xtalate
#MINIO_ROOT_USER=xtalate
#MINIO_ROOT_PASSWORD=xtalate-local-dev
# Host port mappings (change if a port is already taken locally):
#POSTGRES_PORT=5432
#MINIO_PORT=9000
#MINIO_CONSOLE_PORT=9001
#REDIS_PORT=6379
